{
  "name": "rpg",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.9",
  "type": "module",
  "engines": {
    "node": ">=22 <25",
    "pnpm": ">=9 <12"
  },
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:web-only": "vite",
    "typecheck": "tsc --noEmit",
    "verify:version": "node scripts/verify-version.mjs",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage --no-file-parallelism --maxWorkers=1",
    "eval:phase1": "node --experimental-strip-types scripts/run-phase1-eval.ts",
    "eval:phase1:update": "node --experimental-strip-types scripts/run-phase1-eval.ts --update-artifacts",
    "eval:phase1.1": "node scripts/run-phase11-eval.mjs",
    "eval:phase1.1:live": "node scripts/run-phase11-live-eval.mjs",
    "e2e": "playwright test",
    "e2e:install": "playwright install chromium",
    "lint": "eslint .",
    "audit:prod": "pnpm audit --prod",
    "clean": "node scripts/clean.mjs",
    "rust:test": "cargo test --manifest-path src-tauri/Cargo.toml",
    "rust:clippy": "cargo clippy --manifest-path src-tauri/Cargo.toml --all-targets -- -D warnings",
    "rust:audit": "cd src-tauri && cargo audit",
    "desktop:smoke": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/desktop-smoke.ps1",
    "desktop:installed-smoke": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/desktop-installed-smoke.ps1",
    "desktop:installed-smoke:mac": "bash scripts/desktop-installed-smoke-macos.sh",
    "desktop:keychain-smoke:mac": "PHASE2_KEYCHAIN_SMOKE=1 cargo test --manifest-path src-tauri/Cargo.toml tests::os_keychain_round_trip_smoke -- --ignored --exact --nocapture",
    "desktop:product-flow": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/desktop-product-flow.ps1",
    "release:sbom": "node scripts/generate-release-sbom.mjs",
    "release:provenance": "node scripts/create-release-provenance.mjs",
    "verify": "pnpm typecheck && pnpm lint && pnpm test && pnpm eval:phase1 && pnpm eval:phase1.1 && pnpm build && pnpm audit:prod && pnpm rust:test && pnpm rust:clippy",
    "verify:release": "pnpm typecheck && pnpm lint && pnpm test:coverage && pnpm eval:phase1 && pnpm eval:phase1.1 && pnpm build && pnpm e2e && pnpm audit:prod && pnpm rust:audit && pnpm rust:test && pnpm rust:clippy && pnpm desktop:build && pnpm desktop:smoke && pnpm desktop:installed-smoke",
    "verify:release:mac": "pnpm typecheck && pnpm lint && pnpm test:coverage && pnpm eval:phase1 && pnpm eval:phase1.1 && pnpm build && pnpm e2e && pnpm audit:prod && pnpm rust:audit && pnpm rust:test && pnpm rust:clippy && pnpm desktop:build && pnpm desktop:installed-smoke:mac",
    "verify:desktop": "pnpm verify && pnpm desktop:build",
    "tauri": "tauri",
    "desktop:open": "tauri dev",
    "desktop:dev": "tauri dev",
    "desktop:build": "node scripts/desktop-build.mjs"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.11.1",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "1.61.0",
    "@tauri-apps/cli": "^2.11.4",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/node": "^26.0.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "3.2.6",
    "eslint": "^10.6.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.7.0",
    "jsdom": "^25.0.1",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.62.0",
    "vite": "^6.4.3",
    "vitest": "^3.2.6"
  }
}
